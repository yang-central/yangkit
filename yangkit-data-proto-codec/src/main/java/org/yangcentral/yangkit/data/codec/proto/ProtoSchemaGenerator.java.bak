package org.yangcentral.yangkit.data.codec.proto;

import com.google.protobuf.DescriptorProtos;
import org.yangcentral.yangkit.common.api.QName;
import org.yangcentral.yangkit.model.api.schema.YangSchemaContext;
import org.yangcentral.yangkit.model.api.stmt.*;
import org.yangcentral.yangkit.model.api.stmt.ext.YangStructure;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.concurrent.atomic.AtomicInteger;

/**
 * Generator for Protocol Buffers schema from YANG schema.
 * Converts YANG data models to Protobuf descriptor definitions.
 */
public class ProtoSchemaGenerator {
    
    private static final String PROTOBUF_PACKAGE_PREFIX = "yangkit.proto.";
    private final Map<String, DescriptorProtos.DescriptorProto> messageCache;
    private final Map<String, Integer> fieldNumberCache;
    private final AtomicInteger messageCounter;
    
    public ProtoSchemaGenerator() {
        this.messageCache = new HashMap<>();
        this.fieldNumberCache = new HashMap<>();
        this.messageCounter = new AtomicInteger(1);
    }
    
    /**
     * Generate FileDescriptorProto for a YANG module.
     * 
     * @param module the YANG module
     * @return Protobuf FileDescriptorProto
     */
    public DescriptorProtos.FileDescriptorProto generateFileDescriptor(Module module) {
        String packageName = getProtobufPackageName(module);
        
        DescriptorProtos.FileDescriptorProto.Builder fileBuilder = 
            DescriptorProtos.FileDescriptorProto.newBuilder();
        fileBuilder.setName(packageName.replace('.', '/') + ".proto");
        fileBuilder.setPackage(packageName);
        
        // Generate messages for all data nodes in the module
        List<DataNode> dataNodes = module.getDataChildren();
        for (DataNode dataNode : dataNodes) {
            DescriptorProtos.DescriptorProto messageProto = generateMessage(dataNode);
            if (messageProto != null) {
                fileBuilder.addMessageType(messageProto);
            }
        }
        
        return fileBuilder.build();
    }
    
    /**
     * Generate a Protobuf message from a YANG data node.
     * 
     * @param dataNode the YANG data node
     * @return Protobuf DescriptorProto
     */
    public DescriptorProtos.DescriptorProto generateMessage(DataNode dataNode) {
        String messageName = getMessageName(dataNode);
        
        // Check cache first
        if (messageCache.containsKey(messageName)) {
            return messageCache.get(messageName);
        }
        
        DescriptorProtos.DescriptorProto.Builder messageBuilder = 
            DescriptorProtos.DescriptorProto.newBuilder();
        messageBuilder.setName(messageName);
        
        int fieldNumber = 1;
        
        // Add fields based on node type
        if (dataNode instanceof Container) {
            Container container = (Container) dataNode;
            addContainerFields(messageBuilder, container, fieldNumber);
        } else if (dataNode instanceof YangList) {
            YangList list = (YangList) dataNode;
            addListFields(messageBuilder, list, fieldNumber);
        } else if (dataNode instanceof Leaf) {
            Leaf leaf = (Leaf) dataNode;
            addLeafField(messageBuilder, leaf, fieldNumber);
        } else if (dataNode instanceof LeafList) {
            LeafList leafList = (LeafList) dataNode;
            addLeafListField(messageBuilder, leafList, fieldNumber);
        } else if (dataNode instanceof Notification) {
            Notification notification = (Notification) dataNode;
            addNotificationFields(messageBuilder, notification, fieldNumber);
        } else if (dataNode instanceof Rpc) {
            Rpc rpc = (Rpc) dataNode;
            addRpcFields(messageBuilder, rpc, fieldNumber);
        } else if (dataNode instanceof Input) {
            Input input = (Input) dataNode;
            addInputOutputFields(messageBuilder, input, fieldNumber);
        } else if (dataNode instanceof Output) {
            Output output = (Output) dataNode;
            addInputOutputFields(messageBuilder, output, fieldNumber);
        } else if (dataNode instanceof Action) {
            Action action = (Action) dataNode;
            addActionFields(messageBuilder, action, fieldNumber);
        } else if (dataNode instanceof YangStructure) {
            YangStructure structure = (YangStructure) dataNode;
            addStructureFields(messageBuilder, structure, fieldNumber);
        }
        
        DescriptorProtos.DescriptorProto messageProto = messageBuilder.build();
        messageCache.put(messageName, messageProto);
        
        return messageProto;
    }
    
    /**
     * Add fields for a container node.
     */
    private void addContainerFields(DescriptorProtos.DescriptorProto.Builder builder, 
                                    Container container, int startFieldNumber) {
        int fieldNumber = startFieldNumber;
        
        // Get children through ContainerDataNode interface
        List<DataNode> children = container.getDataChildren();
        if (children != null) {
            for (DataNode child : children) {
                if (child instanceof Leaf) {
                    addLeafField(builder, (Leaf) child, fieldNumber++);
                } else if (child instanceof LeafList) {
                    addLeafListField(builder, (LeafList) child, fieldNumber++);
                } else if (child instanceof Container) {
                    addNestedMessageField(builder, (Container) child, fieldNumber++);
                } else if (child instanceof YangList) {
                    addNestedMessageField(builder, (YangList) child, fieldNumber++);
                }
            }
        }
    }
    
    /**
     * Add fields for a list node.
     */
    private void addListFields(DescriptorProtos.DescriptorProto.Builder builder, 
                               YangList list, int startFieldNumber) {
        int fieldNumber = startFieldNumber;
        
        // Add key fields first
        Key key = list.getKey();
        if (key != null) {
            List<Leaf> keyNodes = key.getkeyNodes();
            if (keyNodes != null) {
                for (Leaf keyLeaf : keyNodes) {
                    addLeafField(builder, keyLeaf, fieldNumber++);
                }
            }
        }
        
        // Add other fields
        List<DataNode> children = list.getDataChildren();
        if (children != null) {
            for (DataNode child : children) {
                if (!(child instanceof Key)) {
                    if (child instanceof Leaf) {
                        addLeafField(builder, (Leaf) child, fieldNumber++);
                    } else if (child instanceof LeafList) {
                        addLeafListField(builder, (LeafList) child, fieldNumber++);
                    } else if (child instanceof Container) {
                        addNestedMessageField(builder, (Container) child, fieldNumber++);
                    }
                }
            }
        }
    }
    
    /**
     * Add a leaf field to the message.
     */
    private void addLeafField(DescriptorProtos.DescriptorProto.Builder builder, 
                              Leaf leaf, int fieldNumber) {
        String fieldName = leaf.getIdentifier().getLocalName();
        DescriptorProtos.FieldDescriptorProto.Type protoType = getProtoType(leaf.getType());
        
        DescriptorProtos.FieldDescriptorProto.Builder fieldBuilder = 
            DescriptorProtos.FieldDescriptorProto.newBuilder();
        fieldBuilder.setName(fieldName);
        fieldBuilder.setNumber(fieldNumber);
        fieldBuilder.setType(protoType);
        fieldBuilder.setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_OPTIONAL);
        
        builder.addField(fieldBuilder);
    }
    
    /**
     * Add a leaf-list field to the message.
     */
    private void addLeafListField(DescriptorProtos.DescriptorProto.Builder builder, 
                                  LeafList leafList, int fieldNumber) {
        String fieldName = leafList.getIdentifier().getLocalName();
        DescriptorProtos.FieldDescriptorProto.Type protoType = getProtoType(leafList.getType());
        
        DescriptorProtos.FieldDescriptorProto.Builder fieldBuilder = 
            DescriptorProtos.FieldDescriptorProto.newBuilder();
        fieldBuilder.setName(fieldName);
        fieldBuilder.setNumber(fieldNumber);
        fieldBuilder.setType(protoType);
        fieldBuilder.setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_REPEATED);
        
        builder.addField(fieldBuilder);
    }
    
    /**
     * Add a nested message field.
     */
    private void addNestedMessageField(DescriptorProtos.DescriptorProto.Builder builder, 
                                       DataNode dataNode, int fieldNumber) {
        String fieldName = dataNode.getIdentifier().getLocalName();
        String typeName = getMessageName(dataNode);
        
        // Generate the nested message first
        DescriptorProtos.DescriptorProto nestedMessage = generateMessage(dataNode);
        builder.addNestedType(nestedMessage);
        
        DescriptorProtos.FieldDescriptorProto.Builder fieldBuilder = 
            DescriptorProtos.FieldDescriptorProto.newBuilder();
        fieldBuilder.setName(fieldName);
        fieldBuilder.setNumber(fieldNumber);
        fieldBuilder.setTypeName(typeName);
        fieldBuilder.setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_OPTIONAL);
        
        builder.addField(fieldBuilder);
    }
    
    /**
     * Add anydata field.
     */
    private void addAnydataField(DescriptorProtos.DescriptorProto.Builder builder, 
                                 Anydata anydata, int fieldNumber) {
        String fieldName = anydata.getIdentifier().getLocalName();
        
        DescriptorProtos.FieldDescriptorProto.Builder fieldBuilder = 
            DescriptorProtos.FieldDescriptorProto.newBuilder();
        fieldBuilder.setName(fieldName);
        fieldBuilder.setNumber(fieldNumber);
        fieldBuilder.setType(DescriptorProtos.FieldDescriptorProto.Type.TYPE_BYTES);
        fieldBuilder.setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_OPTIONAL);
        
        builder.addField(fieldBuilder);
    }
    
    /**
     * Add anyxml field.
     */
    private void addAnyxmlField(DescriptorProtos.DescriptorProto.Builder builder, 
                                Anyxml anyxml, int fieldNumber) {
        String fieldName = anyxml.getIdentifier().getLocalName();
        
        DescriptorProtos.FieldDescriptorProto.Builder fieldBuilder = 
            DescriptorProtos.FieldDescriptorProto.newBuilder();
        fieldBuilder.setName(fieldName);
        fieldBuilder.setNumber(fieldNumber);
        fieldBuilder.setType(DescriptorProtos.FieldDescriptorProto.Type.TYPE_STRING);
        fieldBuilder.setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_OPTIONAL);
        
        builder.addField(fieldBuilder);
    }
    
    /**
     * Add notification fields.
     */
    private void addNotificationFields(DescriptorProtos.DescriptorProto.Builder builder, 
                                       Notification notification, int startFieldNumber) {
        // Treat notification similar to container
        List<DataNode> children = notification.getDataChildren();
        if (children != null) {
            int fieldNumber = startFieldNumber;
            for (DataNode child : children) {
                if (child instanceof Leaf) {
                    addLeafField(builder, (Leaf) child, fieldNumber++);
                } else if (child instanceof LeafList) {
                    addLeafListField(builder, (LeafList) child, fieldNumber++);
                } else if (child instanceof Container) {
                    addNestedMessageField(builder, (Container) child, fieldNumber++);
                }
            }
        }
    }
    
    /**
     * Add RPC fields.
     */
    private void addRpcFields(DescriptorProtos.DescriptorProto.Builder builder, 
                              Rpc rpc, int startFieldNumber) {
        // RPC will have input and output as nested messages
        Input input = rpc.getInput();
        if (input != null) {
            // Generate input message
            DescriptorProtos.DescriptorProto inputMessage = generateMessageForInput(input);
            builder.addNestedType(inputMessage);
            
            DescriptorProtos.FieldDescriptorProto.Builder fieldBuilder = 
                DescriptorProtos.FieldDescriptorProto.newBuilder();
            fieldBuilder.setName("input");
            fieldBuilder.setNumber(startFieldNumber++);
            fieldBuilder.setTypeName(inputMessage.getName());
            fieldBuilder.setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_OPTIONAL);
            builder.addField(fieldBuilder);
        }
        
        Output output = rpc.getOutput();
        if (output != null) {
            // Generate output message
            DescriptorProtos.DescriptorProto outputMessage = generateMessageForOutput(output);
            builder.addNestedType(outputMessage);
            
            DescriptorProtos.FieldDescriptorProto.Builder fieldBuilder = 
                DescriptorProtos.FieldDescriptorProto.newBuilder();
            fieldBuilder.setName("output");
            fieldBuilder.setNumber(startFieldNumber);
            fieldBuilder.setTypeName(outputMessage.getName());
            fieldBuilder.setLabel(DescriptorProtos.FieldDescriptorProto.Label.LABEL_OPTIONAL);
            builder.addField(fieldBuilder);
        }
    }
    
    /**
     * Add input/output fields.
     */
    private void addInputOutputFields(DescriptorProtos.DescriptorProto.Builder builder, 
                                      DataNode node, int startFieldNumber) {
        // Treat input/output similar to container
        List<DataNode> children = node.getDataChildren();
        if (children != null) {
            int fieldNumber = startFieldNumber;
            for (DataNode child : children) {
                if (child instanceof Leaf) {
                    addLeafField(builder, (Leaf) child, fieldNumber++);
                } else if (child instanceof LeafList) {
                    addLeafListField(builder, (LeafList) child, fieldNumber++);
                } else if (child instanceof Container) {
                    addNestedMessageField(builder, (Container) child, fieldNumber++);
                }
            }
        }
    }
    
    /**
     * Generate message for Input node.
     */
    private DescriptorProtos.DescriptorProto generateMessageForInput(Input input) {
        String messageName = getMessageName(input);
        DescriptorProtos.DescriptorProto.Builder messageBuilder = 
            DescriptorProtos.DescriptorProto.newBuilder();
        messageBuilder.setName(messageName);
        
        int fieldNumber = 1;
        addInputOutputFields(messageBuilder, input, fieldNumber);
        
        return messageBuilder.build();
    }
    
    /**
     * Generate message for Output node.
     */
    private DescriptorProtos.DescriptorProto generateMessageForOutput(Output output) {
        String messageName = getMessageName(output);
        DescriptorProtos.DescriptorProto.Builder messageBuilder = 
            DescriptorProtos.DescriptorProto.newBuilder();
        messageBuilder.setName(messageName);
        
        int fieldNumber = 1;
        addInputOutputFields(messageBuilder, output, fieldNumber);
        
        return messageBuilder.build();
    }
    
    /**
     * Add action fields.
     */
    private void addActionFields(DescriptorProtos.DescriptorProto.Builder builder, 
                                 Action action, int startFieldNumber) {
        addInputOutputFields(builder, action, startFieldNumber);
    }
    
    /**
     * Add structure fields.
     */
    private void addStructureFields(DescriptorProtos.DescriptorProto.Builder builder, 
                                    YangStructure structure, int startFieldNumber) {
        // Treat structure similar to container
        List<DataNode> children = structure.getDataChildren();
        if (children != null) {
            int fieldNumber = startFieldNumber;
            for (DataNode child : children) {
                if (child instanceof Leaf) {
                    addLeafField(builder, (Leaf) child, fieldNumber++);
                } else if (child instanceof LeafList) {
                    addLeafListField(builder, (LeafList) child, fieldNumber++);
                } else if (child instanceof Container) {
                    addNestedMessageField(builder, (Container) child, fieldNumber++);
                }
            }
        }
    }
    
    /**
     * Get Protobuf type from YANG type.
     */
    private DescriptorProtos.FieldDescriptorProto.Type getProtoType(Type yangType) {
        if (yangType == null) {
            return DescriptorProtos.FieldDescriptorProto.Type.TYPE_STRING;
        }
        
        Restriction<?> restriction = yangType.getRestriction();
        if (restriction == null) {
            return DescriptorProtos.FieldDescriptorProto.Type.TYPE_STRING;
        }
        
        String baseTypeName = restriction.getClass().getSimpleName();
        
        // Map YANG types to Protobuf types
        switch (baseTypeName) {
            case "YangInt8":
            case "YangInt16":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_INT32;
            case "YangInt32":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_INT32;
            case "YangInt64":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_INT64;
            case "YangUint8":
            case "YangUint16":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_UINT32;
            case "YangUint32":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_UINT32;
            case "YangUint64":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_UINT64;
            case "YangBoolean":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_BOOL;
            case "Decimal64":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_DOUBLE;
            case "Enumeration":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_ENUM;
            case "Binary":
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_BYTES;
            case "YangString":
            default:
                return DescriptorProtos.FieldDescriptorProto.Type.TYPE_STRING;
        }
    }
    
    /**
     * Get message name from data node.
     */
    private String getMessageName(DataNode dataNode) {
        QName qName = dataNode.getIdentifier();
        String moduleName = qName.getPrefix();
        String localName = qName.getLocalName();
        
        // Capitalize first letter for message name
        return moduleName + "_" + capitalize(localName);
    }
    
    /**
     * Get Protobuf package name from YANG module.
     */
    private String getProtobufPackageName(Module module) {
        String moduleName = module.getMainModule().getName();
        return PROTOBUF_PACKAGE_PREFIX + moduleName.replace('-', '_');
    }
    
    /**
     * Find a leaf node by name in a data node container.
     */
    private Leaf findLeafByName(DataNode container, String leafName) {
        if (!(container instanceof ContainerLike)) {
            return null;
        }
        
        ContainerLike containerLike = (ContainerLike) container;
        List<DataNode> children = containerLike.getDataChildren();
        
        for (DataNode child : children) {
            if (child instanceof Leaf && child.getIdentifier().getLocalName().equals(leafName)) {
                return (Leaf) child;
            }
        }
        
        return null;
    }
    
    /**
     * Capitalize the first letter of a string.
     */
    private String capitalize(String str) {
        if (str == null || str.isEmpty()) {
            return str;
        }
        return Character.toUpperCase(str.charAt(0)) + str.substring(1);
    }
}
